<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="#ecebeb"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".presentation.MainActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/bottom_nav_container">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Calendar"
                android:id="@+id/tv_CalendarData"
                android:gravity="center"
                android:layout_marginTop="70dp"
                android:textSize="24sp"/>

            <!-- ЗЕЛЕНАЯ КАРТОЧКА С КАЛОРИЯМИ -->
            <FrameLayout
                android:id="@+id/frame1"
                android:layout_width="match_parent"
                android:layout_height="170dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/ic_shape_green"
                android:layout_marginHorizontal="18dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <TextView
                        android:id="@+id/tv_text1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="40dp"
                        android:text="Дневное потреблениe"
                        android:layout_marginHorizontal="20dp"
                        android:textSize="12sp"
                        android:textStyle="bold|italic"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tv_calories_prosent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textSize="40sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="@id/tv_text1"
                        app:layout_constraintTop_toBottomOf="@id/tv_text1" />

                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:layout_width="140dp"
                        android:layout_height="140dp"
                        android:layout_marginHorizontal="12dp"
                        android:progress="50"
                        android:id="@+id/progress_callories"
                        app:indicatorColor="@color/green"
                        app:indicatorSize="130dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:trackColor="@color/white"
                        app:trackThickness="14dp" />

                    <TextView
                        android:id="@+id/tv_calories"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:layout_marginBottom="30dp"
                        android:textColor="@color/black"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="@+id/progress_callories"
                        app:layout_constraintEnd_toEndOf="@id/progress_callories"
                        app:layout_constraintStart_toStartOf="@id/progress_callories"
                        app:layout_constraintTop_toTopOf="@id/progress_callories" />

                    <TextView
                        android:id="@+id/tv_calories_normal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="30dp"
                        app:layout_constraintTop_toTopOf="@id/progress_callories"
                        app:layout_constraintStart_toStartOf="@id/progress_callories"
                        app:layout_constraintEnd_toEndOf="@id/progress_callories"
                        app:layout_constraintBottom_toBottomOf="@id/progress_callories"
                        android:text="2000"/>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </FrameLayout>

            <!-- КАРТОЧКА БЖУ -->
            <FrameLayout
                android:layout_width="match_parent"
                android:background="@drawable/ic_shape_white"
                android:layout_marginTop="14dp"
                android:layout_marginHorizontal="18dp"
                android:layout_marginBottom="10sp"
                android:layout_height="wrap_content"
                android:paddingBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:src="@drawable/frame_5"
                        android:layout_margin="10dp"/>

                    <!-- Углеводы -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:orientation="horizontal"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Углеводы"
                            android:textColor="@color/white_grey"
                            android:textSize="16sp"
                            android:layout_marginHorizontal="20dp"/>
                        <TextView
                            android:id="@+id/tv_carbs_process"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0/"/>
                        <TextView
                            android:id="@+id/tv_carbs_normal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="20dp"
                            android:text="190 g"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:id="@+id/prosent_carbs"
                            android:layout_width="45dp"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:layout_marginHorizontal="20dp"/>
                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progress_carbs"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="20dp"
                            app:trackThickness="16dp"
                            app:indicatorColor="@color/pink"/>
                    </LinearLayout>

                    <!-- Жиры -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:orientation="horizontal"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Жиры"
                            android:textColor="@color/white_grey"
                            android:layout_marginHorizontal="20dp"/>
                        <TextView
                            android:id="@+id/tv_fats_process"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0/"/>
                        <TextView
                            android:id="@+id/tv_fat_normal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="20dp"
                            android:text="98 g"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:id="@+id/prosent_fat"
                            android:layout_width="45dp"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="20dp"
                            android:text="0%" />
                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/fat_progress"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="20dp"
                            app:trackThickness="16dp"
                            app:indicatorColor="@color/yellow" />
                    </LinearLayout>

                    <!-- Белки -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:orientation="horizontal"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Белки"
                            android:layout_weight="1"
                            android:textColor="@color/white_grey"
                            android:layout_marginHorizontal="20dp"/>
                        <TextView
                            android:id="@+id/tv_protein_process"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0/"/>
                        <TextView
                            android:id="@+id/tv_protein_normal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="20dp"
                            android:text="198 g"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:id="@+id/prosent_protein"
                            android:layout_width="45dp"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:layout_marginHorizontal="20dp"/>
                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/protein_progress"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="20dp"
                            app:trackThickness="16dp"
                            app:indicatorColor="@color/blue"/>
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>


            <!-- ЗАВТРАК -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="18dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/ic_shape_white"
                android:orientation="vertical"
                android:paddingBottom="8dp">

                <LinearLayout
                    android:id="@+id/frameAddFood1"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <ImageView android:layout_width="50dp" android:layout_height="50dp" android:layout_marginHorizontal="20dp" android:src="@drawable/orangejuice" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Завтрак" android:textSize="18sp" android:textStyle="bold|italic" />
                    <ImageView android:layout_width="40dp" android:layout_height="40dp" android:layout_marginEnd="20dp" android:src="@drawable/ic_add" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvBreakfast"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="10dp" />
            </LinearLayout>

            <!-- ОБЕД -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="18dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/ic_shape_white"
                android:orientation="vertical"
                android:paddingBottom="8dp">

                <LinearLayout
                    android:id="@+id/frameAddFood2"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <ImageView android:layout_width="50dp" android:layout_height="50dp" android:layout_marginHorizontal="20dp" android:src="@drawable/cooking_food_fried" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Обед" android:textSize="18sp" android:textStyle="bold|italic" />
                    <ImageView android:layout_width="40dp" android:layout_height="40dp" android:layout_marginEnd="20dp" android:src="@drawable/ic_add" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvLunch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:layout_marginHorizontal="10dp" />
            </LinearLayout>

            <!-- УЖИН -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="18dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/ic_shape_white"
                android:orientation="vertical"
                android:paddingBottom="8dp">

                <LinearLayout
                    android:id="@+id/frameAddFood3"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <ImageView android:layout_width="50dp" android:layout_height="50dp" android:layout_marginHorizontal="20dp" android:src="@drawable/food_two" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Ужин" android:textSize="18sp" android:textStyle="bold|italic" />
                    <ImageView android:layout_width="40dp" android:layout_height="40dp" android:layout_marginEnd="20dp" android:src="@drawable/ic_add" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvDinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:layout_marginHorizontal="10dp" />
            </LinearLayout>

            <!-- ПЕРЕКУСЫ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="18dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/ic_shape_white"
                android:orientation="vertical"
                android:paddingBottom="8dp">

                <LinearLayout
                    android:id="@+id/frameAddFood4"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <ImageView android:layout_width="50dp" android:layout_height="50dp" android:layout_marginHorizontal="20dp" android:src="@drawable/food_fruit_fruits_4_svgrepo_com" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Перекусы" android:textSize="18sp" android:textStyle="bold|italic" />
                    <ImageView android:layout_width="40dp" android:layout_height="40dp" android:layout_marginEnd="20dp" android:src="@drawable/ic_add" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvSnacks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:layout_marginHorizontal="10dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- НИЖНЯЯ НАВИГАЦИЯ -->
    <FrameLayout
        android:id="@+id/bottom_nav_container"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="@drawable/ic_shape">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/navigation_home"
                android:layout_width="0dp"
                android:layout_height="30dp"
                android:layout_weight="1"
                android:src="@drawable/ic_home"/>
            <ImageView
                android:id="@+id/navigation_grafic"
                android:layout_width="0dp"
                android:layout_height="30dp"
                android:layout_weight="1"
                android:src="@drawable/ic_grafic"/>
            <ImageView
                android:id="@+id/navigation_food"
                android:layout_width="0dp"
                android:layout_height="30dp"
                android:layout_weight="1"
                android:src="@drawable/ic_food"/>
            <ImageView
                android:id="@+id/navigation_settings"
                android:layout_width="0dp"
                android:layout_height="30dp"
                android:layout_weight="1"
                android:src="@drawable/ic_food"/>
        </LinearLayout>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>