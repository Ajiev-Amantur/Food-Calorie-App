<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="#ecebeb"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

<FrameLayout
    android:id="@+id/frame1"
    android:layout_width="0dp"
    android:layout_height="170dp"
    android:layout_marginTop="100dp"
    android:background="@drawable/ic_shape_green"
    android:layout_marginHorizontal="18dp"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <TextView
            android:id="@+id/tv_text1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="Дневное потреблениe"
            android:maxLength=""
            android:layout_marginHorizontal="20dp"
            android:textSize="12sp"
            android:textStyle="bold|italic"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_prosent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="99%"
            android:textSize="40sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/tv_text1"
            app:layout_constraintTop_toBottomOf="@id/tv_text1" />

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:layout_width="230dp"
            android:layout_height="230dp"
            android:layout_marginHorizontal="12dp"
            android:progress="50"
            app:indicatorColor="@color/red"
            app:indicatorSize="140dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/tv_prosent"
            app:layout_constraintTop_toTopOf="parent"
            app:trackColor="@color/white"
            app:trackThickness="14dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>


</FrameLayout>



    <FrameLayout
        android:layout_width="0dp"
        android:background="@drawable/ic_shape_white"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="10sp"
        android:layout_height="250dp"
        app:layout_constraintTop_toBottomOf="@id/frame1"
        app:layout_constraintStart_toStartOf="@id/frame1"
        app:layout_constraintEnd_toEndOf="@id/frame1">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/frame_5"
                android:layout_margin="10dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Carbs"
                android:textColor="@color/white_grey"

                android:textSize="16sp"

                android:layout_marginHorizontal="20dp"/>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/tv_Carbs_prosent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="55%"
                    android:textStyle="bold"
                    android:layout_marginHorizontal="20dp"/>

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:progress="55"
                    app:trackThickness="16dp"
                    app:trackCornerRadius="8dp"
                    app:trackColor="@color/grey"
                    app:indicatorColor="@color/pink"
                    app:layout_constraintStart_toEndOf="@id/tv_prosent"
                    app:layout_constraintTop_toTopOf="@id/tv_prosent"
                    app:layout_constraintEnd_toEndOf="@id/tv_prosent"/>

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fat"
                android:textColor="@color/white_grey"
                android:textSize="16sp"
                android:layout_marginTop="10dp"
                android:layout_marginHorizontal="20dp"/>
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:text="2%"
                android:textStyle="bold" />

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:trackThickness="16dp"
                app:trackColor="@color/grey"
                android:progress="30"
                app:indicatorColor="@color/yellow" />
        </LinearLayout>



            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Protein"
                android:textSize="16sp"
                android:textColor="@color/white_grey"

                android:layout_marginTop="10dp"
                android:layout_marginHorizontal="20dp"/>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="94%"
                    android:textStyle="bold"
                    android:layout_marginHorizontal="20dp"/>

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:trackThickness="16dp"
                    android:progress="90"
                    app:trackColor="@color/grey"
                    app:indicatorColor="@color/blue"/>
            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="80dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="@drawable/ic_shape">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            >
            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_home"/>

            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_home"/>

            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_home"/>

            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_home"/>


        </LinearLayout>

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>